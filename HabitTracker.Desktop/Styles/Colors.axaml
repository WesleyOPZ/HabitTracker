<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="ColorAppBackground">#0a0a0b</SolidColorBrush>
    <SolidColorBrush x:Key="ColorSidebar">#121214</SolidColorBrush>
    <SolidColorBrush x:Key="ColorSurface">#1a1a1e</SolidColorBrush>
    <SolidColorBrush x:Key="ColorCard">#1e1a1e</SolidColorBrush>
    <SolidColorBrush x:Key="ColorCardHover">#2a2a30</SolidColorBrush>

    <SolidColorBrush x:Key="ColorTextPrimary">#f1f5f9</SolidColorBrush>
    <SolidColorBrush x:Key="ColorTextSecondary">#94a3b8</SolidColorBrush>
    <SolidColorBrush x:Key="ColorTextMuted">#52525b</SolidColorBrush>

    <SolidColorBrush x:Key="ColorBorder">#2a2a30</SolidColorBrush>
    <SolidColorBrush x:Key="ColorAccent">#8b5cf6</SolidColorBrush>
    <SolidColorBrush x:Key="ColorAccentHover">#7c3aed</SolidColorBrush>
    <SolidColorBrush x:Key="ColorDanger">#ef4444</SolidColorBrush>

    <SolidColorBrush x:Key="StatusToDo">#94a3b8</SolidColorBrush>
    <SolidColorBrush x:Key="StatusInProgress">#3b82f6</SolidColorBrush>
    <SolidColorBrush x:Key="StatusDone">#34d399</SolidColorBrush>

    <SolidColorBrush x:Key="DifficultyEasy">#3bb478</SolidColorBrush>
    <SolidColorBrush x:Key="DifficultyNormal">#3b82f6</SolidColorBrush>
    <SolidColorBrush x:Key="DifficultyHard">#ef4444</SolidColorBrush>
    <SolidColorBrush x:Key="DifficultyLegendary">#f59e0b</SolidColorBrush>

    <SolidColorBrush x:Key="DifficultyBgEasy">#152a1e</SolidColorBrush>
    <SolidColorBrush x:Key="DifficultyBgNormal">#1a2640</SolidColorBrush>
    <SolidColorBrush x:Key="DifficultyBgHard">#3a1212</SolidColorBrush>
    <SolidColorBrush x:Key="DifficultyBgLegendary">#3a2a0a</SolidColorBrush>
    <SolidColorBrush x:Key="DifficultyBgDefault">#1f1f22</SolidColorBrush>

    <BoxShadows x:Key="LegendaryGlow">0 0 20 0 #80f59e0b</BoxShadows>

    <SolidColorBrush x:Key="ColorStreak">#f97316</SolidColorBrush>

    <CornerRadius x:Key="RadiusSm">6</CornerRadius>
    <CornerRadius x:Key="RadiusMd">8</CornerRadius>
    <CornerRadius x:Key="RadiusLg">12</CornerRadius>
</ResourceDictionary>
