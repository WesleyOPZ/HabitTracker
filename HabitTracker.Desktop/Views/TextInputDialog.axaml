<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HabitTracker.Desktop.ViewModels"
        x:Class="HabitTracker.Desktop.Views.TextInputDialog"
        x:DataType="vm:TextInputViewModel"
        Title="{Binding Title}"
        Width="320" Height="170"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource ColorSurface}">

    <StackPanel Margin="20" Spacing="12">
        <TextBlock Text="{Binding Label}" Foreground="{StaticResource ColorTextSecondary}" FontSize="13"/>
        <TextBox Text="{Binding Text}" Watermark="{Binding Label}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}"/>
            <Button Classes="primary" Content="Confirm" Command="{Binding ConfirmCommand}"/>
        </StackPanel>
    </StackPanel>


</Window>
