<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HabitTracker.Desktop.ViewModels"
        xmlns:cp="using:Avalonia.Controls"
        x:Class="HabitTracker.Desktop.Views.ColorPickerDialog"
        x:DataType="vm:ColorPickerViewModel"
        Title="Cor da Coluna"
        Width="340" Height="440"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource ColorSurface}">

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}" />
            <Button Classes="primary" Content="Confirm" Command="{Binding ConfirmCommand}" />
        </StackPanel>

        <cp:ColorView Color="{Binding Color}" />

    </DockPanel>


</Window>
