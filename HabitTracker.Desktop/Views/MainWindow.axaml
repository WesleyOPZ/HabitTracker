<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HabitTracker.Desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="using:HabitTracker.Desktop.Converters"
        xmlns:desktopModels="using:HabitTracker.Desktop.Models"
        xmlns:views="using:HabitTracker.Desktop.Views"
        mc:Ignorable="d"
        d:DesignWidth="1200"
        d:DesignHeight="700"
        x:Class="HabitTracker.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="HabitTracker"
        Background="{StaticResource ColorAppBackground}"
        MinWidth="950"
        MinHeight="650"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        SystemDecorations="BorderOnly">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Resources>
        <converters:TabVisibilityConverter x:Key="TabVisibilityConverter" />
        <converters:TabActiveBackgroundConverter x:Key="TabActiveBackgroundConverter" />
        <converters:TabActiveForegroundConverter x:Key="TabActiveForegroundConverter" />
        <converters:XpRatioToWidthConverter x:Key="XpRatioToWidthConverter" />
    </Window.Resources>

    <DockPanel>
        <!-- ========================================== -->
        <!--               CUSTOM TITLEBAR              -->
        <!-- ========================================== -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource ColorSurface}"
                Height="40"
                PointerPressed="TitleBar_PointerPressed">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,0">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Text="🎯"
                               FontSize="16"
                               VerticalAlignment="Center" />
                    <TextBlock Text="HabitTracker"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ColorTextPrimary}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="0"
                            VerticalAlignment="Center">
                    <Button Classes="winbtn"
                            Content="─"
                            Click="MinimizeButton_Click" />
                    <Button Classes="winbtn close"
                            Content="✕"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid ColumnDefinitions="Auto, *">

            <!-- ========================================== -->
            <!--                  SIDEBAR                   -->
            <!-- ========================================== -->
            <Border Grid.Column="0"
                    Width="68"
                    Background="{StaticResource ColorSidebar}"
                    BorderBrush="{StaticResource ColorBorder}"
                    BorderThickness="0,0,1,0">

                <Grid RowDefinitions="Auto, *, Auto, Auto" Margin="0,16">

                    <!-- TOPO: AVATAR BOTÃO + BARRA XP CUSTOM -->
                    <StackPanel Grid.Row="0" Spacing="8" HorizontalAlignment="Center" Margin="0,0,0,16">

                        <!-- Avatar Clicável (Abre a aba Profile) -->
                        <Button Command="{Binding ShowTabCommand}"
                                CommandParameter="{x:Static desktopModels:ActiveTab.Profile}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Width="36"
                                Height="36"
                                CornerRadius="18"
                                HorizontalAlignment="Center"
                                ToolTip.Tip="{Binding LevelName, StringFormat='\{0\} (Nível \{1\}) - Ver Perfil'}">
                            <Border Width="36"
                                    Height="36"
                                    CornerRadius="18"
                                    Background="{StaticResource ColorAccent}"
                                    ClipToBounds="True">
                                <TextBlock Text="👤"
                                           FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </Button>

                        <!-- Barra de XP Customizada do Usuário -->
                        <Border Width="40"
                                Height="4"
                                CornerRadius="2"
                                ClipToBounds="True"
                                Background="{StaticResource ColorSurface}">

                            <ToolTip.Tip>
                                <StackPanel Orientation="Horizontal" Spacing="4" Margin="4">
                                    <TextBlock Text="Level Progress: " FontWeight="SemiBold"
                                               Foreground="{StaticResource ColorTextPrimary}" />
                                    <TextBlock Text="{Binding XpInCurrentLevel}"
                                               Foreground="{StaticResource ColorTextPrimary}" />
                                    <TextBlock Text=" / " Foreground="{StaticResource ColorTextMuted}" />
                                    <TextBlock Text="{Binding XpForNextLevel}"
                                               Foreground="{StaticResource ColorTextPrimary}" />
                                    <TextBlock Text=" XP " Foreground="{StaticResource ColorAccent}" FontWeight="Bold" />
                                </StackPanel>
                            </ToolTip.Tip>

                            <Border HorizontalAlignment="Left"
                                    CornerRadius="2"
                                    Background="{StaticResource ColorAccent}">

                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource XpRatioToWidthConverter}">
                                        <Binding Path="XpInCurrentLevel" />
                                        <Binding Path="XpForNextLevel" />
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Border>

                    </StackPanel>

                    <!-- CENTRO: BOTÕES DE NAVEGAÇÃO VERTICAL -->
                    <StackPanel Grid.Row="1" Spacing="8" HorizontalAlignment="Center" Width="48">

                        <!-- Botão Hábitos -->
                        <Button Classes="nav"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Height="40"
                                Padding="0"
                                Background="{Binding ActiveTab, Converter={StaticResource TabActiveBackgroundConverter}, ConverterParameter=Habits}"
                                Foreground="{Binding ActiveTab, Converter={StaticResource TabActiveForegroundConverter}, ConverterParameter=Habits}"
                                Command="{Binding ShowTabCommand}"
                                CommandParameter="{x:Static desktopModels:ActiveTab.Habits}"
                                ToolTip.Tip="Hábitos">
                            <TextBlock Text="📋" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>

                        <!-- Botão Conquistas -->
                        <Button Classes="nav"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Height="40"
                                Padding="0"
                                Background="{Binding ActiveTab, Converter={StaticResource TabActiveBackgroundConverter}, ConverterParameter=Achievements}"
                                Foreground="{Binding ActiveTab, Converter={StaticResource TabActiveForegroundConverter}, ConverterParameter=Achievements}"
                                Command="{Binding ShowTabCommand}"
                                CommandParameter="{x:Static desktopModels:ActiveTab.Achievements}"
                                ToolTip.Tip="Conquistas">
                            <TextBlock Text="🏆" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>

                    <!-- RODAPÉ -->
                    <StackPanel Grid.Row="2" Spacing="8" VerticalAlignment="Bottom">
                        <Button HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Height="40"
                                Padding="0"
                                Margin="0,0,0,4"
                                CornerRadius="6"
                                Background="{Binding ActiveTab, Converter={StaticResource TabActiveBackgroundConverter}, ConverterParameter=Settings}"
                                Foreground="{Binding ActiveTab, Converter={StaticResource TabActiveForegroundConverter}, ConverterParameter=Settings}"
                                Command="{Binding ShowTabCommand}"
                                CommandParameter="{x:Static desktopModels:ActiveTab.Settings}"
                                ToolTip.Tip="Settings">

                            <Button.Styles>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Background" Value="{StaticResource ColorSurface}" />
                                </Style>
                            </Button.Styles>

                            <TextBlock Text="⚙️" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>

                        <TextBlock
                            Text="{Binding AppVersion}"
                            FontSize="9"
                            Foreground="{StaticResource ColorTextSecondary}"
                            HorizontalAlignment="Center"
                            Opacity="0.4" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ========================================== -->
            <!--          PAINEL DE CONTEÚDO PRINCIPAL      -->
            <!-- ========================================== -->
            <Grid Grid.Column="1" Margin="24">

                <!-- ABA: HABITS -->
                <views:HabitsView
                    IsVisible="{Binding ActiveTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=Habits}" />

                <!-- ABA: ACHIEVEMENTS -->
                <views:AchievementsView
                    IsVisible="{Binding ActiveTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=Achievements}" />

                <!-- ABA: PROFILE (UNIFICADA) -->
                <views:ProfileView
                    IsVisible="{Binding ActiveTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=Profile}" />

                <!-- ABA: Settings -->
                <Grid IsVisible="{Binding ActiveTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=Settings}">
                    <TextBlock Text="Settings"
                               Foreground="{StaticResource ColorTextSecondary}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="15"
                               FontStyle="Italic"
                               Opacity="0.5" />
                </Grid>

            </Grid>
        </Grid>
    </DockPanel>
</Window>
