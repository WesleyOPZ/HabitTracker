<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HabitTracker.Desktop.ViewModels"
        xmlns:models="using:HabitTracker.Core.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="using:HabitTracker.Desktop.Converters"
        xmlns:desktopModels="clr-namespace:HabitTracker.Desktop.Models"
        mc:Ignorable="d"
        d:DesignWidth="1200"
        d:DesignHeight="700"
        x:Class="HabitTracker.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="HabitTracker"
        Background="{StaticResource ColorAppBackground}"
        MinWidth="950"
        MinHeight="650"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        SystemDecorations="BorderOnly">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Resources>
        <converters:CategoryDisplayConverter x:Key="CategoryDisplayConverter" />
        <converters:TabVisibilityConverter x:Key="TabVisibilityConverter" />
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
        <converters:TabActiveBackgroundConverter x:Key="TabActiveBackgroundConverter" />
        <converters:TabActiveForegroundConverter x:Key="TabActiveForegroundConverter" />
        <converters:DifficultyColorConverter x:Key="DifficultyColorConverter" />
        <converters:DifficultyBgConverter x:Key="DifficultyBgConverter" />
        <converters:XpRatioToWidthConverter x:Key="XpRatioToWidthConverter" />
    </Window.Resources>

    <DockPanel>
        <!-- ========================================== -->
        <!--               CUSTOM TITLEBAR              -->
        <!-- ========================================== -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource ColorSurface}"
                Height="40"
                PointerPressed="TitleBar_PointerPressed">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,0">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Text="🎯"
                               FontSize="16"
                               VerticalAlignment="Center" />
                    <TextBlock Text="HabitTracker"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ColorTextPrimary}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="0"
                            VerticalAlignment="Center">
                    <Button Classes="winbtn"
                            Content="─"
                            Click="MinimizeButton_Click" />
                    <Button Classes="winbtn close"
                            Content="✕"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid ColumnDefinitions="Auto, *">

            <!-- ========================================== -->
            <!--                  SIDEBAR                   -->
            <!-- ========================================== -->
            <Border Grid.Column="0"
                    Width="68"
                    Background="{StaticResource ColorSidebar}"
                    BorderBrush="{StaticResource ColorBorder}"
                    BorderThickness="0,0,1,0">

                <Grid RowDefinitions="Auto, *, Auto" Margin="0,16">

                    <!-- TOPO: AVATAR BOTÃO + BARRA XP CUSTOM -->
                    <StackPanel Grid.Row="0" Spacing="8" HorizontalAlignment="Center" Margin="0,0,0,16">

                        <!-- Avatar Clicável (Abre a aba Profile) -->
                        <Button Command="{Binding ShowTabCommand}"
                                CommandParameter="{x:Static desktopModels:ActiveTab.Profile}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Width="36"
                                Height="36"
                                CornerRadius="18"
                                HorizontalAlignment="Center"
                                ToolTip.Tip="{Binding LevelName, StringFormat='\{0\} (Nível \{1\}) - Ver Perfil'}">
                            <Border Width="36"
                                    Height="36"
                                    CornerRadius="18"
                                    Background="{StaticResource ColorAccent}"
                                    ClipToBounds="True">
                                <TextBlock Text="👤"
                                           FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </Button>

                        <!-- Barra de XP Customizada do Usuário -->
                        <Border Width="40"
                                Height="4"
                                CornerRadius="2"
                                ClipToBounds="True"
                                Background="{StaticResource ColorSurface}"
                                ToolTip.Tip="{Binding CurrentXp, StringFormat='XP: \{0\}'}">
                            <Border HorizontalAlignment="Left"
                                    CornerRadius="2"
                                    Background="{StaticResource ColorAccent}">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource XpRatioToWidthConverter}">
                                        <Binding Path="XpInCurrentLevel" />
                                        <Binding Path="XpForNextLevel" />
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Border>

                    </StackPanel>

                    <!-- CENTRO: BOTÕES DE NAVEGAÇÃO VERTICAL -->
                    <StackPanel Grid.Row="1" Spacing="8" HorizontalAlignment="Center" Width="48">

                        <!-- Botão Hábitos -->
                        <Button Classes="nav"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Height="40"
                                Padding="0"
                                Background="{Binding ActiveTab, Converter={StaticResource TabActiveBackgroundConverter}, ConverterParameter=Habits}"
                                Foreground="{Binding ActiveTab, Converter={StaticResource TabActiveForegroundConverter}, ConverterParameter=Habits}"
                                Command="{Binding ShowTabCommand}"
                                CommandParameter="{x:Static desktopModels:ActiveTab.Habits}"
                                ToolTip.Tip="Hábitos">
                            <TextBlock Text="📋" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>

                        <!-- Botão Conquistas -->
                        <Button Classes="nav"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Height="40"
                                Padding="0"
                                Background="{Binding ActiveTab, Converter={StaticResource TabActiveBackgroundConverter}, ConverterParameter=Achievements}"
                                Foreground="{Binding ActiveTab, Converter={StaticResource TabActiveForegroundConverter}, ConverterParameter=Achievements}"
                                Command="{Binding ShowTabCommand}"
                                CommandParameter="{x:Static desktopModels:ActiveTab.Achievements}"
                                ToolTip.Tip="Conquistas">
                            <TextBlock Text="🏆" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>

                    </StackPanel>

                    <!-- RODAPÉ -->
                    <TextBlock Grid.Row="2"
                               Text="v1.0"
                               FontSize="9"
                               Foreground="{StaticResource ColorTextSecondary}"
                               HorizontalAlignment="Center"
                               Opacity="0.4" />
                </Grid>
            </Border>

            <!-- ========================================== -->
            <!--          PAINEL DE CONTEÚDO PRINCIPAL      -->
            <!-- ========================================== -->
            <Grid Grid.Column="1" Margin="24">

                <!-- ABA: HABITS -->
                <Grid
                    IsVisible="{Binding ActiveTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=Habits}"
                    RowDefinitions="Auto, *">

                    <!-- Topo: Filtro de Categoria e Novo Hábito -->
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="6,0,6,16">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="📁 Category:"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource ColorTextSecondary}"
                                       FontSize="13" />
                            <ComboBox ItemsSource="{Binding Categories}"
                                      SelectedItem="{Binding SelectedCategory}"
                                      Width="150"
                                      Background="{StaticResource ColorSurface}"
                                      Foreground="{StaticResource ColorTextPrimary}"
                                      BorderBrush="{StaticResource ColorBorder}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource CategoryDisplayConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="primary"
                                Content="+ New Habit"
                                Command="{Binding OpenCreateHabitCommand}" />
                    </Grid>

                    <!-- Quadro Kanban (As 3 Colunas) -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding KanbanColumns}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" Columns="3" Margin="0" HorizontalAlignment="Stretch" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:KanbanColumnViewModel">
                                <Border Background="{StaticResource ColorSidebar}" CornerRadius="8" Margin="6"
                                        Padding="12">
                                    <DockPanel LastChildFill="True">

                                        <!-- Cabeçalho da Coluna -->
                                        <Border DockPanel.Dock="Top" Background="{StaticResource ColorSurface}"
                                                CornerRadius="6" Padding="8,4" Margin="0,0,0,10">
                                            <DockPanel>
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="Bold"
                                                           FontSize="14"
                                                           Foreground="{StaticResource ColorTextPrimary}"
                                                           VerticalAlignment="Center" />
                                                <Border Background="{StaticResource ColorBorder}"
                                                        CornerRadius="10"
                                                        Padding="6,2"
                                                        HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding Habits.Count}"
                                                               FontSize="12"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource ColorTextSecondary}" />
                                                </Border>
                                            </DockPanel>
                                        </Border>

                                        <!-- Lista de Cards Rolável -->
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding Habits}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>

                                                        <!-- CARD DO HÁBITO -->
                                                        <!-- Usamos Classes e Estilos Locais para controlar as Bordas por Estado e Glow Lendário -->
                                                        <Border Classes="card" Margin="0,0,0,10" Padding="14"
                                                                CornerRadius="8"
                                                                Background="{StaticResource ColorCard}"
                                                                BorderThickness="1"
                                                                BorderBrush="{StaticResource ColorBorder}">

                                                            <!-- Menu de contexto (botão direito no card) para abrir Histórico e Excluir hábito -->
                                                            <Border.ContextMenu>
                                                                <ContextMenu Background="{StaticResource ColorSurface}"
                                                                             BorderBrush="{StaticResource ColorBorder}"
                                                                             x:CompileBindings="False">
                                                                    <MenuItem Header="📅 Ver Histórico"
                                                                              Command="{Binding $parent[Window].DataContext.OpenHabitHistoryCommand}"
                                                                              CommandParameter="{Binding}" />

                                                                    <MenuItem Header="🗑️ Excluir Hábito"
                                                                              Command="{Binding $parent[Window].DataContext.DeleteHabitCommand}"
                                                                              CommandParameter="{Binding}"
                                                                              Foreground="#FF4A4A" />
                                                                </ContextMenu>
                                                            </Border.ContextMenu>

                                                            <!-- Definição de Estilos Avançados para o Card -->
                                                            <Border.Styles>
                                                                <Style Selector="Button#BtnMoveBack">
                                                                    <Setter Property="Opacity" Value="0.0" />
                                                                    <Setter Property="Transitions">
                                                                        <Transitions>
                                                                            <DoubleTransition Property="Opacity"
                                                                                    Duration="0:0:0.15" />
                                                                        </Transitions>
                                                                    </Setter>
                                                                </Style>
                                                                <Style
                                                                    Selector="Border#LeftZone:pointerover Button#BtnMoveBack">
                                                                    <Setter Property="Opacity" Value="1.0" />
                                                                </Style>

                                                                <Style Selector="Button#BtnMoveForward">
                                                                    <Setter Property="Opacity" Value="0.0" />
                                                                    <Setter Property="Transitions">
                                                                        <Transitions>
                                                                            <DoubleTransition Property="Opacity"
                                                                                    Duration="0:0:0.15" />
                                                                        </Transitions>
                                                                    </Setter>
                                                                </Style>
                                                                <Style
                                                                    Selector="Border#RightZone:pointerover Button#BtnMoveForward">
                                                                    <Setter Property="Opacity" Value="1.0" />
                                                                </Style>
                                                            </Border.Styles>

                                                            <Grid Margin="-14">
                                                                <!-- CAMADA DE BAIXO: conteúdo normal do card -->
                                                                <StackPanel Spacing="8" Margin="14">

                                                                    <DockPanel>
                                                                        <TextBlock Text="{Binding Name}" FontSize="15"
                                                                                FontWeight="Bold"
                                                                                Foreground="{StaticResource ColorTextPrimary}"
                                                                                TextWrapping="Wrap" MaxWidth="180" />
                                                                        <Border
                                                                            Background="{Binding Difficulty, Converter={StaticResource DifficultyBgConverter}}"
                                                                            CornerRadius="4" Padding="6,2"
                                                                            HorizontalAlignment="Right"
                                                                            VerticalAlignment="Top">
                                                                            <TextBlock Text="{Binding Difficulty}"
                                                                                    FontSize="10" FontWeight="Bold"
                                                                                    Foreground="{Binding Difficulty, Converter={StaticResource DifficultyColorConverter}}" />
                                                                        </Border>
                                                                    </DockPanel>

                                                                    <TextBlock Text="{Binding Description}"
                                                                               FontSize="12"
                                                                               Foreground="{StaticResource ColorTextSecondary}"
                                                                               TextWrapping="Wrap" Margin="0,2,0,4"
                                                                               IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                                                                    <WrapPanel Orientation="Horizontal" Margin="0,2">
                                                                        <Border
                                                                            Background="{StaticResource ColorSurface}"
                                                                            CornerRadius="4" Padding="4,2"
                                                                            Margin="0,0,6,0">
                                                                            <TextBlock Text="{Binding Category}"
                                                                                    FontSize="10"
                                                                                    Foreground="{StaticResource ColorTextSecondary}" />
                                                                        </Border>
                                                                        <StackPanel Orientation="Horizontal"
                                                                                VerticalAlignment="Center">
                                                                            <TextBlock Text="✨ +" FontSize="10"
                                                                                    Foreground="{StaticResource ColorAccent}" />
                                                                            <TextBlock Text="{Binding XpGainedToday}"
                                                                                    FontSize="10" FontWeight="Bold"
                                                                                    Foreground="{StaticResource ColorAccent}" />
                                                                            <TextBlock Text=" XP" FontSize="10"
                                                                                    Foreground="{StaticResource ColorAccent}" />
                                                                        </StackPanel>
                                                                    </WrapPanel>

                                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                                        <TextBlock Text="🔥" FontSize="12" />
                                                                        <TextBlock Text="{Binding CurrentStreak}"
                                                                                FontSize="12"
                                                                                FontWeight="Bold"
                                                                                Foreground="{StaticResource ColorTextPrimary}" />
                                                                        <TextBlock Text="streak days" FontSize="11"
                                                                                Foreground="{StaticResource ColortextSeconday}"
                                                                                VerticalAlignment="Center" />
                                                                    </StackPanel>

                                                                    <!-- Espaço reservado embaixo pros botões não tampar o texto -->
                                                                    <Border Height="28" />
                                                                </StackPanel>

                                                                <!-- CAMADA DE CIMA: zonas de hover ocupando o card inteiro -->
                                                                <Grid x:Name="ActionGrid"
                                                                      ColumnDefinitions="*, *"
                                                                      x:CompileBindings="False">

                                                                    <Border Grid.Column="0"
                                                                            x:Name="LeftZone"
                                                                            Background="Transparent">
                                                                        <Button x:Name="BtnMoveBack"
                                                                                Command="{Binding $parent[Window].DataContext.MoveHabitBackCommand}"
                                                                                CommandParameter="{Binding}"
                                                                                Content="◀"
                                                                                ToolTip.Tip="Mover para trás"
                                                                                Background="Transparent"
                                                                                BorderThickness="0"
                                                                                Padding="8,4"
                                                                                Width="36"
                                                                                HorizontalAlignment="Left"
                                                                                HorizontalContentAlignment="Center"
                                                                                VerticalAlignment="Stretch"
                                                                                VerticalContentAlignment="Center" />
                                                                    </Border>

                                                                    <Border Grid.Column="1"
                                                                            x:Name="RightZone"
                                                                            Background="Transparent">
                                                                        <Button x:Name="BtnMoveForward"
                                                                                Command="{Binding $parent[Window].DataContext.MoveHabitForwardCommand}"
                                                                                CommandParameter="{Binding}"
                                                                                Content="▶"
                                                                                ToolTip.Tip="Mover para frente"
                                                                                Background="Transparent"
                                                                                BorderThickness="0"
                                                                                Padding="8,4"
                                                                                Width="36"
                                                                                HorizontalAlignment="Right"
                                                                                HorizontalContentAlignment="Center"
                                                                                VerticalAlignment="Stretch"
                                                                                VerticalContentAlignment="Center" />
                                                                    </Border>
                                                                </Grid>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <!-- ABA: ACHIEVEMENTS -->
                <ScrollViewer
                    IsVisible="{Binding ActiveTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=Achievements}">
                    <ItemsControl ItemsSource="{Binding Achievements}" Margin="20">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Achievement">
                                <Border Classes="card"
                                        Padding="20"
                                        Margin="0,0,0,12"
                                        Opacity="{Binding IsUnlocked, Converter={StaticResource BoolToOpacityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icon}" FontSize="28" VerticalAlignment="Center"
                                                   Margin="0,0,16,0" />
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"
                                                       Foreground="{StaticResource ColorTextPrimary}" />
                                            <TextBlock Text="{Binding Description}" FontSize="12"
                                                       Foreground="{StaticResource ColorTextSecondary}"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- ABA: PROFILE (UNIFICADA COM DETALHES DE PERFORMANCE/ESTATÍSTICAS) -->
                <ScrollViewer
                    IsVisible="{Binding ActiveTab, Converter={StaticResource TabVisibilityConverter}, ConverterParameter=Profile}">
                    <StackPanel Margin="20" Spacing="16">

                        <!-- Card Detalhado do Perfil do Usuário -->
                        <Border Classes="card" Padding="24">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <Border Width="72" Height="72" CornerRadius="36"
                                            Background="{StaticResource ColorSurface}">
                                        <TextBlock Text="👤" FontSize="32" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ProfileUserName}" FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource ColorTextPrimary}" />
                                        <TextBlock FontSize="13" Foreground="{StaticResource ColorTextSecondary}">
                                            <Run Text="Level " />
                                            <Run Text="{Binding Level}" FontWeight="Bold" />
                                            <Run Text=" · " />
                                            <Run Text="{Binding LevelName}" />
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Text="{Binding ProfileDescription}" FontSize="13"
                                           Foreground="{StaticResource ColorTextSecondary}" TextWrapping="Wrap" />

                                <WrapPanel Orientation="Horizontal">
                                    <Border Background="{StaticResource ColorSurface}"
                                            CornerRadius="{StaticResource RadiusSm}" Padding="10,6" Margin="0,0,8,8">
                                        <TextBlock FontSize="12" Foreground="{StaticResource ColorTextPrimary}">
                                            <Run Text="⚧ " />
                                            <Run Text="{Binding ProfileGender}" />
                                        </TextBlock>
                                    </Border>
                                    <Border Background="{StaticResource ColorSurface}"
                                            CornerRadius="{StaticResource RadiusSm}" Padding="10,6" Margin="0,0,8,8">
                                        <TextBlock FontSize="12" Foreground="{StaticResource ColorTextPrimary}">
                                            <Run Text="🎂 " />
                                            <Run Text="{Binding ProfileDateOfBirth}" />
                                        </TextBlock>
                                    </Border>
                                    <Border Background="{StaticResource ColorSurface}"
                                            CornerRadius="{StaticResource RadiusSm}" Padding="10,6" Margin="0,0,8,8">
                                        <TextBlock FontSize="12" Foreground="{StaticResource ColorTextPrimary}">
                                            <Run Text="📅 Member since " />
                                            <Run Text="{Binding ProfileMemberSince}" />
                                        </TextBlock>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Card de Estatísticas Gerais Incorporado -->
                        <Border Classes="card" Padding="24">
                            <StackPanel Spacing="12">
                                <TextBlock Text="📊 Overview de Performance" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource ColorTextPrimary}" Margin="0,0,0,4" />

                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" RowSpacing="10"
                                      ColumnSpacing="10">
                                    <!-- Bloco de XP Total -->
                                    <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource ColorSurface}"
                                            Padding="14" CornerRadius="8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="⭐ Total XP Acumulado" FontSize="12"
                                                       Foreground="{StaticResource ColorTextSecondary}" />
                                            <TextBlock Text="{Binding CurrentXp}" FontSize="18" FontWeight="Bold"
                                                       Foreground="{StaticResource ColorTextPrimary}" />
                                        </StackPanel>
                                    </Border>

                                    <!-- Bloco de Streaks de Dias -->
                                    <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource ColorSurface}"
                                            Padding="14" CornerRadius="8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="🔥 Global Longest Streak" FontSize="12"
                                                       Foreground="{StaticResource ColorTextSecondary}" />
                                            <TextBlock Text="{Binding GlobalLongestStreak, StringFormat='\{0\} days'}"
                                                       FontSize="18" FontWeight="Bold"
                                                       Foreground="{StaticResource ColorTextPrimary}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Botões de Ação do Perfil -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Classes="primary" Content="✏️ Edit Profile"
                                    Command="{Binding OpenEditProfileCommand}" Padding="16,10" />
                            <Button Classes="secondary" Content="👁 Preview" Padding="16,10" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Grid>
    </DockPanel>
</Window>
